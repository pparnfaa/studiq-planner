# -----------------------------
# Project: studiq
# Copy this file to `.env`
# -----------------------------

# App environment
APP_ENV=development
TZ=Asia/Bangkok

# Ports on host machine
POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=5173

# PostgreSQL credentials/database
POSTGRES_DB=studiq
POSTGRES_USER=studiq_user
POSTGRES_PASSWORD=studiq_pass

# Backend configuration
# For local frontend (Vite) access
CORS_ORIGINS=http://localhost:5173

# Frontend configuration
# Browser calls backend on host machine
VITE_API_URL=http://localhost:8080
